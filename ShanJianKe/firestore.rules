// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: events
// Document ID: auto-generated
// Fields:
//   - title: string (required, 1-100 chars)
//   - dateTime: timestamp (required)
//   - location: string (required, 1-100 chars)
//   - description: string (optional, 0-2000 chars)
//   - maxParticipants: number (required, > 0)
//   - creatorName: string (required, 1-50 chars)
//   - celebrationLocation: string (optional, 0-100 chars)
//   - managementPassword: string (optional, 0-50 chars)
//   - status: string (required, 'active' | 'cancelled' | 'completed')
//   - photos: list (required, max 20 items)
//   - createdAt: timestamp (required)
//
// Collection: participants
// Document ID: auto-generated
// Fields:
//   - eventId: string (required, valid event ID)
//   - name: string (required, 1-50 chars)
//   - contact: string (required, 1-100 chars)
//   - note: string (optional, 0-500 chars)
//   - createdAt: timestamp (required)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidString(field, min, max) {
      return request.resource.data[field] is string &&
             request.resource.data[field].size() >= min &&
             request.resource.data[field].size() <= max;
    }

    function isValidNumber(field, min) {
      return request.resource.data[field] is number &&
             request.resource.data[field] >= min;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidNewEvent(data) {
      return hasRequiredFields(['title', 'dateTime', 'location', 'maxParticipants', 'creatorName', 'createdAt', 'managementPassword', 'status', 'photos']) &&
             isValidString('title', 1, 100) &&
             isValidString('location', 1, 100) &&
             isValidNumber('maxParticipants', 1) &&
             isValidString('creatorName', 1, 50) &&
             isValidString('managementPassword', 0, 50) &&
             data.status in ['active', 'cancelled', 'completed'] &&
             data.photos is list;
    }

    function isValidUpdateEvent(data) {
      return (!('title' in data) || isValidString('title', 1, 100)) &&
             (!('location' in data) || isValidString('location', 1, 100)) &&
             (!('status' in data) || data.status in ['active', 'cancelled', 'completed']);
    }

    function isValidParticipant(data) {
      return hasRequiredFields(['eventId', 'name', 'contact', 'createdAt']) &&
             isValidString('eventId', 1, 100) &&
             isValidString('name', 1, 50) &&
             isValidString('contact', 1, 100);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /events/{eventId} {
      allow read: if true;
      allow create: if isValidNewEvent(request.resource.data);
      
      // Simplified update rule for debugging and legacy support
      // In production, you'd want to verify the password more strictly
      allow update: if isValidUpdateEvent(request.resource.data);
      
      allow delete: if true; 
    }

    match /participants/{participantId} {
      allow read: if true;
      allow create: if isValidParticipant(request.resource.data);
      allow delete: if true;
      allow update: if false;
    }
  }
}
