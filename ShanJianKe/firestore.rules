// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: events
// Document ID: auto-generated
// Fields:
//   - title: string (required, 1-100 chars)
//   - dateTime: timestamp (required)
//   - location: string (required, 1-100 chars)
//   - description: string (optional, 0-2000 chars)
//   - maxParticipants: number (required, > 0)
//   - creatorName: string (required, 1-50 chars)
//   - createdAt: timestamp (required)
//
// Collection: participants
// Document ID: auto-generated
// Fields:
//   - eventId: string (required, valid event ID)
//   - name: string (required, 1-50 chars)
//   - contact: string (required, 1-100 chars)
//   - note: string (optional, 0-500 chars)
//   - createdAt: timestamp (required)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidString(field, min, max) {
      return request.resource.data[field] is string &&
             request.resource.data[field].size() >= min &&
             request.resource.data[field].size() <= max;
    }

    function isValidNumber(field, min) {
      return request.resource.data[field] is number &&
             request.resource.data[field] >= min;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidEvent(data) {
      return hasRequiredFields(['title', 'dateTime', 'location', 'maxParticipants', 'creatorName', 'createdAt']) &&
             hasOnlyAllowedFields(['title', 'dateTime', 'location', 'description', 'maxParticipants', 'creatorName', 'createdAt']) &&
             isValidString('title', 1, 100) &&
             isValidString('location', 1, 100) &&
             isValidNumber('maxParticipants', 1) &&
             isValidString('creatorName', 1, 50) &&
             data.dateTime is timestamp &&
             data.createdAt is timestamp;
    }

    function isValidParticipant(data) {
      return hasRequiredFields(['eventId', 'name', 'contact', 'createdAt']) &&
             hasOnlyAllowedFields(['eventId', 'name', 'contact', 'note', 'createdAt']) &&
             isValidString('eventId', 1, 100) &&
             isValidString('name', 1, 50) &&
             isValidString('contact', 1, 100) &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /events/{eventId} {
      // Anyone can read events to see the list and details
      allow read: if true;
      
      // Only authenticated users can create events
      allow create: if isAuthenticated() && isValidEvent(request.resource.data);
      
      // Updates are not allowed for now to keep it simple, or only by creator if we had UIDs
      // For MVP, we allow anyone to read, but creation is protected.
      allow update, delete: if false; 
    }

    match /participants/{participantId} {
      // Anyone can read participants to count them
      allow read: if true;
      
      // Anyone can join an event (MVP doesn't require auth for joining, but we could add it)
      allow create: if isValidParticipant(request.resource.data);
      
      allow update, delete: if false;
    }
  }
}
